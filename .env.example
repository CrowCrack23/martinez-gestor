# Supabase — comparte el mismo proyecto con martinez-global
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Sesión: ≥32 chars. Genera uno con: node scripts/hash-password.mjs --secret
SESSION_SECRET=

# URL pública (para enlaces absolutos si hicieran falta)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Asistente IA (Mastra). El servidor debe estar FUERA de Cuba (OpenAI/Google bloquean IPs cubanas).
# Configura al menos UNA de las tres; el admin elige el proveedor en la UI.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Modelos por proveedor (opcional, valores por defecto si se omiten)
MASTRA_MODEL_OPENAI=openai/gpt-4o-mini
MASTRA_MODEL_ANTHROPIC=anthropic/claude-3-5-haiku-20241022
MASTRA_MODEL_GOOGLE=google/gemini-2.0-flash
